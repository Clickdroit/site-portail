# Server
PORT=3000

# JWT Secret (change this!)
JWT_SECRET=change-me-to-a-random-string

# Default admin credentials
ADMIN_USER=admin
ADMIN_PASS=admin

# Health-check worker interval (ms)
PING_INTERVAL_MS=60000

# GitHub OAuth (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Docker socket path (optional, for restart command)
# DOCKER_SOCKET=/var/run/docker.sock

# GitHub Actions webhook URL (optional, for deploy command)
# DEPLOY_WEBHOOK_URL=
# DEPLOY_WEBHOOK_SECRET=
